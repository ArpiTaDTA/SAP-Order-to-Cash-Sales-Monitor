{
  "_version": "1.58.0",
  "sap.app": {
    "id": "sap.ui.demo.salesorders",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "2.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}"
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "rootView": {
      "viewName": "sap.ui.demo.salesorders.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sap.ui.demo.salesorders.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "sap.ui.demo.salesorders.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "pattern": "",
          "name": "worklist",
          "target": "worklist"
        },
        {
          "pattern": "SalesOrders/{index}",
          "name": "object",
          "target": "object"
        },
        {
          "pattern": "notFound",
          "name": "notFound",
          "target": "notFound"
        }
      ],
      "targets": {
        "worklist": {
          "viewId": "worklist",
          "viewName": "Worklist"
        },
        "object": {
          "viewId": "object",
          "viewName": "Object"
        },
        "notFound": {
          "viewId": "notFound",
          "viewName": "NotFound"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    }
  }
}
